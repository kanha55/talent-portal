# AI provider: cursor (default when CURSOR_API_KEY is set) or openai
AI_PROVIDER=cursor

# Cursor — get a key from https://cursor.com/dashboard/integrations
CURSOR_API_KEY=
CURSOR_MODEL=composer-2.5

# OpenAI-compatible fallback (optional)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
