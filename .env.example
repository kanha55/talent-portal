# On Vercel with both keys, Cursor is used by default. Force OpenAI with AI_PROVIDER=openai.
AI_PROVIDER=cursor

# Cursor — get a key from https://cursor.com/dashboard/integrations
CURSOR_API_KEY=
CURSOR_MODEL=composer-2.5

# OpenAI-compatible fallback (recommended on Vercel serverless)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Production database (required on Vercel — free tier at https://upstash.com)
# Use the REST API tab values (https://...), NOT the redis:// connection string.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# If you linked Upstash via Vercel Storage, these may be set instead:
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# Signup notifications (free tier at https://resend.com)
ADMIN_NOTIFICATION_EMAIL=
RESEND_API_KEY=
# Until you verify a domain, use: Talent Portal <onboarding@resend.dev>
RESEND_FROM_EMAIL=Talent Portal <onboarding@resend.dev>

# Local file store path (optional — defaults to data/app-store.json)
# STORE_PATH=
